# =========================
# Wallet / RPC
# =========================
SOLANA_PRIVATE_KEY=            # your base58-encoded private key
WALLET_PRIVATE_KEY=            # optional alias
SOLANA_PUBLIC_KEY=             # your wallet’s public key
WALLET_PUBLIC_KEY=             # optional alias

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_TIMEOUT=20

TELEGRAM_BOT_TOKEN=       # from BotFather
TELEGRAM_CHAT_ID=       # your numeric ID

HELIUS_API_KEY=  #your Helius API Key

# ==============================
# Jupiter (Lite) defaults
# ==============================
# Base host for Lite tier
JUP_BASE=https://lite-api.jup.ag
# Default slippage for quotes (basis points)
JUP_SLIPPAGE_BPS=50
# Swap build flags
JUP_WRAP_UNWRAP_SOL=1
JUP_USE_SHARED_ACCOUNTS=1
# Priority fee (micro-lamports); 0 = none, try 1000–5000 if fills are slow
JUP_CU_PRICE=0

# Keep existing execution flags (paper trading)
JUPITER_EXECUTE=0
JUPITER_QUOTE_ONLY=1

# ==============================
# Discovery / Fetching
# ==============================
DEXSCREENER_QUERY=solana
# If set, takes priority over DEXSCREENER_QUERY:
DEXSCREENER_QUERIES=solana,bonk,pepe,cat,doge,degen,ai,game,pump,moon

# Page & size controls
DEX_PAGES=3
DEX_PER_PAGE=100
DEX_MAX=600

# ---- Rate & concurrency tuning (to avoid 429s) ----
DEXSCREENER_RPM=200
DISCOVERY_BATCH_SIZE=3
DISCOVERY_BATCH_SLEEP=1.0
DISCOVERY_MAX_TOKENS_PER_CYCLE=240
ENRICHMENT_MAX_TOKENS_PER_CYCLE=200

AIOHTTP_CONN_LIMIT=50
# Helpful on Windows to avoid IPv6/UA quirks:
# DEX_FORCE_IPV4=1
# DEX_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36

DISCOVERY_CYCLE_SECONDS=60

# ==============================
# Raydium (KEEP OFF until next version) BIG Pain in the Ass currently
# ==============================
RAYDIUM_ENABLE=0
FORCE_DISABLE_RAYDIUM=1
# RAYDIUM_MAX_PAIRS=100
# RAYDIUM_MAX_DOWNLOAD_MB=40
# MIN_LIQUIDITY_USD=50000
# MIN_VOLUME24_USD=0
# MIN_MARKETCAP_USD=0

# ==============================
# Birdeye (disable if you don't have an API key )
# ==============================
BIRDEYE_ENABLE=1
FORCE_DISABLE_BIRDEYE=0
BIRDEYE_API_KEY=
BIRDEYE_RPS=5
BIRDEYE_MAX_CALLS_PER_CYCLE=60
BIRDEYE_MAX_CALLS_PER_RUN=2000

# ==============================
# RugCheck 
# ==============================
RUGCHECK_ENABLE=false
RUGCHECK_JWT=
RUGCHECK_JWT_TOKEN=
RUGCHECK_DISCOVERY_CHECK=true
BLOCK_RUGCHECK_DANGEROUS=false
RUGCHECK_HARDFAIL=0

# ==============================
# UI / Shortlist
# ==============================
TOP_N_PER_CATEGORY=20
GUI_TOP_N_PER_CATEGORY=20
GUI_DEV_MODE=false
SOLANABOT_NO_ENV_MIGRATE=1
SHORTLIST_PER_CATEGORY=5
ALWAYS_HIDE_SYMBOLS=SOL,WSOL,USDC,USDT,WRAPPED SOLANA

# ==============================
# DRY-RUN / SAFETY SWITCHES
# ==============================
DRY_RUN=1
DISABLE_SEND_TX=1
PAPER_BUDGET_SOL=1.0