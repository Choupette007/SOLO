# =========================
# SOLO Meme Coin Trading Bot - CONFIG (Dry Run)
# =========================

# ---- Top-level paths expected by the loader/GUI ----
db_path: "C:\\Users\\Admin\\AppData\\Local\\SOLOTradingBot\\tokens.sqlite3"
log_path: "C:\\Users\\Admin\\AppData\\Local\\SOLOTradingBot\\logs\\bot.log"

# -------- RugCheck configuration --------
rugcheck:
  enabled: true
  api_base: "https://api.rugcheck.xyz/v1"
  allow_if_api_down: true
  hard_fail_on_missing_auth: false
  block_dangerous_on_trade: true
  jwt_env: "RUGCHECK_JWT"
  api_key_env: "RUGCHECK_API_KEY"
  danger_labels_blocklist: ["dangerous", "scam", "honeypot", "malicious", "blocked"]

# -------- Wallet --------
wallet:
  address: "YOUR_WALLET_ADDRESS"
  private_key_env: "SOLANA_PRIVATE_KEY"
  secret_key_env: "SOLANA_PRIVATE_KEY"
  min_balance_sol: 0.00

# -------- Solana (launcher & bot) --------
solana:
  rpc_url: "https://api.mainnet-beta.solana.com"
  rpc_endpoint: "https://api.mainnet-beta.solana.com"
  rpc_timeout_seconds: 15

# -------- Database & Logging --------
database:
  token_cache_path: "C:\\Users\\Admin\\AppData\\Local\\SOLOTradingBot\\tokens.sqlite3"

logging:
  log_file_path: "C:\\Users\\Admin\\AppData\\Local\\SOLOTradingBot\\logs\\bot.log"
  level: "INFO"
  max_bytes: 2000000
  backup_count: 3
  # Optional structured logs — requires small code change to enable JSON output
  structured: false

paths:
  token_cache_path: "C:\\Users\\Admin\\AppData\\Local\\SOLOTradingBot\\tokens.sqlite3"
  log_dir: "C:\\Users\\Admin\\AppData\\Local\\SOLOTradingBot\\logs"

# -------- Source toggles --------
sources:
  raydium_enabled: 0
  birdeye_enabled: 1

# -------- API/Discovery controls (Balanced + optimizations) --------
discovery:
  workset_cap: 80
  quality_cap: 50
  new_coin_cap: 30
  spike_cap: 0

  exclude_symbols:
    - WSOL
    - Wrapped SOL
    - USDC
    - USDT
    - JUPSOL
    - Jupiter Staked SOL
    - JITOSOL
    - MSOL
    - BSOL
    - STSOL
  exclude_addresses:
    - So11111111111111111111111111111111111111112
    - EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
    - jupSoLaHXQiZZTSfEWMTRRgpnyFm8f6sZdosWBjx93v

  # Reduce pages/per-page to avoid Dexscreener 429s (balanced)
  dexscreener_pages: 4
  dexscreener_per_page: 75
  dexscreener_queries:
    - solana
    - bonk
    - pepe
    - doge
    - cat
    - meme
    - pump
    - moon
    - degen
    - ai
    - game

  dexscreener_post_cap: 300
  raydium_max_pairs: 0
  raydium_page_size: 0

  # Increase Birdeye coverage so depth checks are more reliable
  birdeye_max_tokens: 400

  # shortlist size tuned for manual review
  shortlist_per_bucket: 5

  # Backoff & retry tuning
  backoff_max_retries: 5
  backoff_base_delay: 1.0
  # Optional runtime flags the code can use (requires the code patch to actually use jitter)
  backoff_jitter_enabled: true
  backoff_max_sleep_seconds: 120
  # Circuit-breaker: pause discovery for X seconds after N consecutive 429s (requires code)
  circuit_breaker_on_429: true
  circuit_breaker_429_threshold: 5
  circuit_breaker_cooldown_seconds: 60

  # Keep RugCheck lookup optional at discovery so new tokens remain visible
  rugcheck_in_discovery: false
  require_rugcheck_pass: false

  # Price-change guardrail (percent values & depth thresholds)
  max_price_change: 350.0                # soft threshold (percent)
  max_price_change_hard: 2000.0          # hard safety cap (percent)
  min_price_for_pct: 0.0001              # nominal price floor to trust percent
  min_liq_for_big_pct: 5000.0            # USD liquidity required for very large pct moves
  min_vol_for_big_pct: 10000.0           # USD 24h volume required for very large pct moves

  # Probation / review behavior for borderline runners (requires code to persist state)
  probation_enabled: true
  probation_cycles_required: 2           # require depth_ok for N consecutive cycles
  probation_persist_minutes: 30
  review_bucket_enabled: true            # keep borderline tokens for manual review instead of dropping

  # Newly launched: keep <= 180 minutes as requested
  newly_launched:
    max_token_age_minutes: 180
    liquidity_threshold: 500
    volume_threshold: 500
    max_rugcheck_score: 5000

  low_cap:
    max_market_cap: 300000
    liquidity_threshold: 1000
    volume_threshold: 800
    max_rugcheck_score: 5000

  mid_cap:
    max_market_cap: 5000000
    liquidity_threshold: 3000
    volume_threshold: 2000
    max_rugcheck_score: 5000

  large_cap:
    liquidity_threshold: 8000
    volume_threshold: 5000
    max_rugcheck_score: 5000

# -------- Holders (enabled to support depth checks) --------
holders:
  enabled: true
  timeout_seconds: 8
  allow_if_api_down: true
  min_holders:
    low_cap: 25
    mid_cap: 75
    large_cap: 200
    newly_launched: 20
  providers:
    birdeye:
      api_key: "${BIRDEYE_API_KEY}"
      holders_url: "https://api.birdeye.so/defi/token/holders"
      overview_url: "https://api.birdeye.so/defi/token/overview"
    solscan_pro:
      api_key: "${SOLSCAN_PRO_API_KEY}"
    helius:
      api_key: "${HELIUS_API_KEY}"
      url: "https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}"
      method_summary: "getTokenHoldersSummary"
      method_top: "getTokenTopHolders"
    public_solscan:
      enabled: true

concentration:
  enabled: false
  top_n: 10
  allow_if_api_down: true
  max_percent_per_category:
    low_cap: 30
    mid_cap: 35
    large_cap: 40
    newly_launched: 30

# -------- Signals & Patterns --------
signals:
  enable: true
  ranking_tilt: true
  ohlcv:
    interval: "1m"
    limit: 200
  rsi:
    enable: true
    period: 14
  macd:
    enable: true
    fast: 12
    slow: 26
    signal: 9
  bollinger:
    enable: true
    period: 20
    stddev: 2.0
  td9:
    enable: true
    lookback: 30

patterns:
  enable: true
  list: ["bullish_engulfing","bearish_engulfing","hammer","shooting_star","doji"]

# -------- Trading runtime (dry-run safe) --------
trading:
  enabled: true
  dry_run: true
  simulate: true
  send_transactions: false
  paper_trade_ledger: true

  prefer_persisted_shortlist: false
  db_shortlist_max_age_s: 120
  db_shortlist_min_count: 10

  min_order_usd: 25
  max_order_usd: 500
  max_open_positions: 5
  slippage_bps: 150

  risk:
    block_if_safety_unknown: false
    require_rugcheck_pass_for_trade: false

  jupiter:
    use_version: 6
    route_mode: "ExactIn"

# -------- Scoring (balanced) --------
scoring:
  mode: "midcap"
  presence_boost_if_birdeye: 1.00
  penalty_if_missing_birdeye: 1.00

# -------- Bot sizing & exits --------
bot:
  enabled: true
  dry_run: true

  # Keep legacy buy_percentage, but prefer risk-based sizing when available.
  buy_percentage: 0.10
  max_risk_pct_of_portfolio: 0.05
  min_usd_per_buy: 25.0
  per_trade_sol: 0
  required_sol: 0.00

  # dynamic slippage settings (code support required to use)
  dynamic_slippage:
    enabled: true
    base_bps: 150
    depth_based_adjustment_enabled: true
    extra_bps_for_low_depth: 50

  buy_slippage_bps: 150
  sell_slippage_bps: 150
  paper_budget_sol: 1.0

  profit_target: 1.25
  stop_loss: 0.85
  max_hold_hours: 24

  tp1_x: 1.30
  tp2_x: 2.00
  tp1_pct_to_sell: 0.50
  tp2_pct_of_remaining: 0.60
  breakeven_plus: 0.02
  trail_pct_after_tp1: 0.18
  trail_pct_moonbag: 0.30
  no_tp_cutoff_hours: 6.0
  no_tp_min_profit_x: 1.10

  cycle_interval: 45
  cooldown_seconds: 6

  slippage_bps: 150
  max_open_positions: 5
  min_order_usd: 25
  max_order_usd: 500
  block_if_safety_unknown: false
  require_rugcheck_pass_for_trade: false

  jupiter:
    use_version: 6
    route_mode: "ExactIn"

  jupiter_preflight:
    enabled: true
    dust_quote_lamports_min: 1000000
    dust_quote_fraction_of_buy: 0.01

# -------- Notifications --------
notifications:
  telegram:
    enabled: true
    bot_token_env: "TELEGRAM_BOT_TOKEN"
    chat_id_env: "TELEGRAM_CHAT_ID"
  email:
    enabled: false
    smtp_server: ""
    smtp_user_env: "SMTP_USER"
    smtp_pass_env: "SMTP_PASS"
    to: []

# -------- Weights (balanced) --------
weights:
  market_cap: 0.20
  liquidity: 0.20
  volume: 0.25
  price_change: 0.25
  new_token_bonus: 0.15

# -------- Observability (opt-in) --------
observability:
  metrics_enabled: false
  metrics_port: 9000
  prometheus_exporter_enabled: false
  structured_logs_enabled: false

