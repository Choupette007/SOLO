# =========================
# Wallet / RPC
# =========================
SOLANA_PRIVATE_KEY=            # your base58-encoded private key
WALLET_PRIVATE_KEY=            # optional alias
SOLANA_PUBLIC_KEY=             # your wallet’s public key
WALLET_PUBLIC_KEY=             # optional alias

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_TIMEOUT=20

# =========================
# Aggregators
# =========================
# Dexscreener
DEX_PAGES=30
DEX_PER_PAGE=100
DEX_MAX=1000
DEXSCREENER_QUERY=solana

# Birdeye
BIRDEYE_ENABLE=true
BIRDEYE_API_KEY=               # insert your Birdeye API key
BIRDEYE_MAX_TOKENS=500

# Raydium
RAYDIUM_ENABLE=true
RAYDIUM_PAGE_SIZE=10
RAYDIUM_MAX_PAIRS=800
RAYDIUM_MAX_POOLS=2000
RAYDIUM_MAX_DOWNLOAD_MB=85

# =========================
# Rugcheck
# =========================
RUGCHECK_ENABLE=true
RUGCHECK_JWT=                  # paste Rugcheck JWT token here if available
RUGCHECK_JWT_TOKEN=            # alias (some helpers use this name)
RUGCHECK_API_KEY=              # optional, if Rugcheck provides API key instead of JWT

BLOCK_RUGCHECK_DANGEROUS=false
RUGCHECK_HARD_FAIL=false
RUGCHECK_DISCOVERY_CHECK=true
RUGCHECK_DISCOVERY_FILTER=false

# =========================
# GUI / Bot shortlist alignment
# =========================
TOP_N_PER_CATEGORY=20
GUI_TOP_N_PER_CATEGORY=20
GUI_DEV_MODE=false

# =========================
# Internal
# =========================
SOLANABOT_NO_ENV_MIGRATE=1

